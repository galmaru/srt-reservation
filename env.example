# 이 파일을 .env 로 복사한 뒤 실제 정보를 입력하세요
# cp env.example .env

# ──────────────────────────────────────
# Provider 설정
# ──────────────────────────────────────
# "srt" 또는 "ktx"
PROVIDER=srt

# ──────────────────────────────────────
# 로그인 정보 (provider에 맞는 항목 입력)
# ──────────────────────────────────────
SRT_ID=010-1234-5678
SRT_PW=your_srt_password

KTX_ID=010-1234-5678
KTX_PW=your_ktx_password

# ──────────────────────────────────────
# 예매 설정
# ──────────────────────────────────────
DEP_STATION=수서
ARR_STATION=부산
TRAVEL_DATE=20260403
TRAVEL_TIME=080000

# 좌석 설정 (GENERAL_FIRST / GENERAL_ONLY / SPECIAL_FIRST / SPECIAL_ONLY)
SEAT_TYPE=GENERAL_FIRST

# 인원 설정
ADULT_COUNT=1

# ──────────────────────────────────────
# 결제 설정 (SRT 전용, AUTO_PAY=true 시 사용)
# ──────────────────────────────────────
AUTO_PAY=false
CARD_NUMBER=
CARD_PASSWORD=
CARD_VALIDATION_NUMBER=
CARD_EXPIRE_DATE=
CARD_INSTALLMENT=0

# ──────────────────────────────────────
# Slack 알림 (선택사항)
# ──────────────────────────────────────
# 미설정 시 알림 없이 정상 동작
SLACK_WEBHOOK_URL=

# ──────────────────────────────────────
# ntfy 푸시 알림 (선택사항)
# ──────────────────────────────────────
# ntfy 앱 설치 후 토픽 구독: https://ntfy.sh
# 예) NTFY_TOPIC_URL=https://ntfy.sh/내토픽명
# 자체 서버 예) NTFY_TOPIC_URL=https://my-ntfy.example.com/내토픽명
NTFY_TOPIC_URL=

# ──────────────────────────────────────
# Flask 설정
# ──────────────────────────────────────
# Vercel 배포 시 반드시 설정 (미설정 시 재시작마다 세션 무효화)
SECRET_KEY=
