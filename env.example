# 이 파일을 .env 로 복사한 뒤 실제 정보를 입력하세요
# cp env.example .env

# SRT 로그인 정보
SRT_ID=010-1234-5678
SRT_PW=your_password

# 예매 설정
DEP_STATION=수서
ARR_STATION=부산
TRAVEL_DATE=20260403
TRAVEL_TIME=080000

# 좌석 설정 (GENERAL_FIRST / GENERAL_ONLY / SPECIAL_FIRST / SPECIAL_ONLY)
SEAT_TYPE=GENERAL_FIRST

# 인원 설정
ADULT_COUNT=1

# 자동 결제 설정 (선택사항 - true 시 자동 결제 진행)
AUTO_PAY=false
CARD_NUMBER=
CARD_PASSWORD=
CARD_VALIDATION_NUMBER=
CARD_EXPIRE_DATE=
CARD_INSTALLMENT=0
